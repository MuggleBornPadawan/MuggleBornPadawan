;; --- Org-mode LaTeX Integration ---
(with-eval-after-load 'org
  ;; Use dvisvgm to generate crisp SVG previews of LaTeX formulas in buffers
  (setq org-latex-create-formula-image-program 'dvisvgm)
  (setq org-preview-latex-default-process 'dvisvgm)
  
  ;; Configure PDF compilation to use latexmk (handles multiple passes automatically)
  (setq org-latex-pdf-process
        '("latexmk -f -pdf -interaction=nonstopmode -output-directory=%o %f")))


(use-package exec-path-from-shell
  :ensure t
  :config
  (exec-path-from-shell-initialize))
;; Set the default rendering process (dvisvgm produces sharp vector graphics)
(setq org-preview-latex-default-process 'dvisvgm)
;;(setq org-preview-latex-default-process 'dvipng)













(defun my/display-emojis ()
  "Display all standard emoji blocks in a new buffer."
  (interactive)
  (let ((buf (get-buffer-create "*Emojis*"))
        (ranges '((#x1F600 . #x1F64F)   ; Emoticons
                  (#x1F300 . #x1F5FF)   ; Misc Symbols & Pictographs
                  (#x1F680 . #x1F6FF)   ; Transport & Map
                  (#x1F900 . #x1F9FF)   ; Supplemental Symbols
                  (#x1FA70 . #x1FAFF)   ; Symbols & Pictographs Ext
                  (#x2600 . #x26FF)     ; Misc Symbols
                  (#x2700 . #x27BF))))  ; Dingbats
    (with-current-buffer buf
      (read-only-mode -1)
      (erase-buffer)
      (text-scale-set 2) ; Make emojis larger
      (dolist (range ranges)
        (let ((start (car range))
              (end (cdr range)))
          (while (<= start end)
            (when (char-displayable-p start)
              (insert (char-to-string start) " "))
            (setq start (1+ start)))
          (insert "\n\n")))
      (view-mode 1))
    (pop-to-buffer buf)))

"""
### How to use:
1. Copy the code into your `*scratch*` buffer.
2. Place your cursor after the last parenthesis and press `C-x C-e` to evaluate it.
3. Run `M-x my/display-emojis`.

